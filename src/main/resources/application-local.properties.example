# 로컬 전용 설정 예시 (민감 정보 포함)
# 이 파일을 복사해 application-local.properties 로 저장한 뒤 값을 채우세요.
# application-local.properties 는 .gitignore 되어 있어 저장소에 올라가지 않습니다.
#
# 사용 방법: 실행 시 프로필을 local 로 지정
#   - IDE: Run Configuration > Active profiles: local
#   - 터미널: ./gradlew bootRun --args='--spring.profiles.active=local'
#
# application.properties 의 같은 키는 이 파일 값으로 덮어씌워집니다 (충돌 없음).

# DB (필요 시 로컬 DB 비밀번호 등)
# spring.datasource.password=your-local-password

# OAuth - 로컬에서 소셜 로그인 테스트 시
app.oauth.base-url=http://localhost:8080
app.oauth.google.client-id=your-google-client-id
app.oauth.google.client-secret=your-google-client-secret
app.oauth.kakao.client-id=your-kakao-rest-api-key
app.oauth.kakao.client-secret=kakao-secret
