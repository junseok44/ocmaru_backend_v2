# 컨테이너 기동 시 docker-entrypoint.sh 가 __SCRAPE_TARGET__ 를 PROMETHEUS_SCRAPE_TARGET 로 치환합니다.
# 예: PROMETHEUS_SCRAPE_TARGET=api.example.com:8080

global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: "ocmaru-server"
    metrics_path: "/actuator/prometheus"
    static_configs:
      - targets:
          - "__SCRAPE_TARGET__"
